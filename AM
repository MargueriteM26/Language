.activity-card .card-emoji { font-size: 2.8em; margin-bottom: 10px; }
.activity-card h3 { font-family: 'Baloo 2', sans-serif; font-size: 1.15em; color: var(--navy); margin-bottom: 6px; }
.activity-card p { font-size: 0.88em; color: #555; line-height: 1.5; }
.line-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 0.78em; font-weight: 700; margin-top: 10px; color: white; }

/* BUTTONS */
.btn {
  display: inline-block;
  padding: 11px 26px;
  border: none;
  border-radius: 30px;
  font-family: 'Baloo 2', sans-serif;
  font-weight: 700;
  font-size: 0.95em;
  cursor: pointer;
  transition: all 0.18s;
  letter-spacing: 0.3px;
}
.btn-red { background: var(--red); color: white; box-shadow: 0 4px 0 #8b0000; }
.btn-red:hover { transform: translateY(-2px); box-shadow: 0 6px 0 #8b0000; }
.btn-red:active { transform: translateY(2px); box-shadow: 0 2px 0 #8b0000; }
.btn-navy { background: var(--navy); color: white; box-shadow: 0 4px 0 #001a4f; }
.btn-navy:hover { transform: translateY(-2px); }
.btn-yellow { background: var(--yellow); color: var(--navy); box-shadow: 0 4px 0 #c4a200; }
.btn-yellow:hover { transform: translateY(-2px); }
.btn-green { background: var(--green); color: white; box-shadow: 0 4px 0 #003d1a; }
.btn-green:hover { transform: translateY(-2px); }

/* ACTIVITY AREAS */
.activity-container { max-width: 680px; margin: 22px auto; padding: 0 16px 40px; }
.progress-bar-wrap { background: rgba(0,54,136,0.14); border-radius: 10px; height: 11px; margin-bottom: 18px; overflow: hidden; }
.progress-bar-fill { height: 100%; background: var(--navy); border-radius: 10px; transition: width 0.4s ease; }
.card { background: white; border-radius: 16px; padding: 22px; box-shadow: 0 4px 16px rgba(0,54,136,0.12); margin-bottom: 14px; }
.question-number { font-family: 'Baloo 2', sans-serif; font-size: 0.88em; color: var(--red); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
.score-display { display: flex; align-items: center; gap: 6px; font-family: 'Baloo 2', sans-serif; font-weight: 700; color: var(--navy); font-size: 1.05em; }
.back-btn { background: none; border: none; color: var(--navy); font-family: 'Nunito', sans-serif; font-weight: 700; cursor: pointer; font-size: 0.93em; display: flex; align-items: center; gap: 5px; margin-bottom: 14px; padding: 4px 0; }
.back-btn:hover { text-decoration: underline; }

/* ACTIVITY 1 */
.clue-box {
  background: var(--navy);
  color: white;
  border-radius: 12px;
  padding: 14px 18px;
  margin-bottom: 10px;
  font-size: 0.97em;
  line-height: 1.55;
  animation: slideIn 0.3s ease;
}
@keyframes slideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.clue-label { font-family: 'Baloo 2', sans-serif; font-size: 0.8em; color: var(--yellow); font-weight: 700; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 1px; }
.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin-top: 14px; }
.option-btn {
  padding: 11px 14px;
  background: white;
  border: 2px solid var(--navy);
  border-radius: 10px;
  font-family: 'Nunito', sans-serif;
  font-size: 0.92em;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
  color: var(--navy);
  text-align: left;
}
.option-btn:hover:not(:disabled) { background: var(--navy); color: white; transform: scale(1.02); }
.option-btn.correct { background: #d4edda; border-color: #28a745; color: #155724; }
.option-btn.wrong { background: #f8d7da; border-color: #dc3545; color: #721c24; }
.feedback-box { padding: 14px 16px; border-radius: 12px; margin-top: 14px; font-size: 0.95em; font-weight: 600; line-height: 1.5; animation: slideIn 0.3s ease; }
.feedback-correct { background: #d4edda; color: #155724; border: 2px solid #28a745; }
.feedback-wrong { background: #f8d7da; color: #721c24; border: 2px solid #dc3545; }

/* STEP DOTS */
.step-dots { display: flex; gap: 6px; margin-bottom: 14px; align-items: center; }
.step-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(0,54,136,0.2); transition: background 0.3s; }
.step-dot.done { background: var(--navy); }
.step-dot.active { background: var(--red); width: 12px; height: 12px; }

/* ACTIVITY 2 */
.phrase-preview {
  background: var(--navy);
  color: white;
  border-radius: 12px;
  padding: 16px 18px;
  margin-bottom: 16px;
  font-family: 'Baloo 2', sans-serif;
  font-size: 1.1em;
  line-height: 1.65;
  min-height: 68px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px;
}
.phrase-adj { color: #90EE90; font-weight: 700; }
.phrase-noun { color: var(--yellow); font-weight: 800; }
.phrase-post { color: #ADD8E6; font-style: italic; }
.adj-bank { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
.adj-chip {
  padding: 6px 15px;
  border-radius: 20px;
  border: 2px solid var(--navy);
  background: white;
  color: var(--navy);
  font-weight: 700;
  font-family: 'Nunito', sans-serif;
  cursor: pointer;
  transition: all 0.15s;
  font-size: 0.9em;
  user-select: none;
}
.adj-chip:hover { background: #e6eeff; }
.adj-chip.selected { background: var(--navy); color: white; }
.post-options { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.post-option {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  background: #f5f5f5;
  border-radius: 10px;
  border: 2px solid transparent;
  cursor: pointer;
  transition: all 0.15s;
  font-size: 0.92em;
  font-weight: 600;
  color: #222;
  line-height: 1.45;
}
.post-option:hover { background: #e8f0ff; border-color: var(--navy); }
.post-option.selected { background: #d9e8ff; border-color: var(--navy); }
.post-option input[type=radio] { accent-color: var(--navy); width: 17px; height: 17px; flex-shrink: 0; margin-top: 2px; }
.section-label { font-weight: 700; color: var(--navy); margin-bottom: 7px; font-size: 0.93em; }
.hint-text { font-size: 0.83em; color: #777; margin-bottom: 9px; font-style: italic; }

/* END */
.end-container { max-width: 600px; margin: 36px auto; padding: 20px; text-align: center; }
.certificate {
  background: white;
  border: 5px solid var(--navy);
  border-radius: 20px;
  padding: 32px;
  box-shadow: 0 4px 16px rgba(0,54,136,0.14);
  position: relative;
  overflow: hidden;
}
.certificate::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 8px;
  background: linear-gradient(90deg, #DC241F 0%, #FFD329 20%, #00853F 40%, #003688 60%, #DC241F 80%, #FFD329 100%);
}
.cert-title { font-family: 'Baloo 2', sans-serif; font-size: 1.9em; color: var(--navy); margin: 14px 0 6px; }
.cert-score { font-family: 'Baloo 2', sans-serif; font-size: 3.2em; color: var(--red); font-weight: 800; margin: 6px 0; }
.cert-msg { font-size: 0.97em; color: #444; margin-bottom: 22px; line-height: 1.65; }
.nav-buttons { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }

@media (max-width: 500px) {
  .activity-cards { grid-template-columns: 1fr; }
  .options-grid { grid-template-columns: 1fr; }
  .main-title { font-size: 1.4em; }
}
</style>
</head>
<body>

<!-- HOME SCREEN -->
<div id="home" class="screen">
  <div class="tube-header">
    <div class="main-title">🚇 London Underground Adventure</div>
    <div class="header-sub">Year 4 English Activity</div>
  </div>
  <div class="home-container">
    <div class="home-intro">
      <h2>🎒 All aboard!</h2>
      <p>Welcome to the London Underground English Adventure! You'll use your reading skills to work out which station you're at — and then build some seriously impressive expanded noun phrases about what you see.</p>
