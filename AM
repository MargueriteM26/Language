</div>

<!-- ACTIVITY 2: PHRASE BUILDER -->
<div id="act2" class="screen">
  <div class="tube-header">
    <div class="main-title">✍️ Phrase Builder</div>
  </div>
  <div class="activity-container">
    <button class="back-btn" onclick="goHome()">← Back to menu</button>
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
      <div id="a2-counter" class="question-number">Phrase 1 of 4</div>
      <div class="score-display">⭐ <span id="a2-score">0</span></div>
    </div>
    <div class="progress-bar-wrap"><div class="progress-bar-fill" id="a2-progress" style="width: 0%;"></div></div>
    <div class="card">
      <div id="a2-station" style="font-family:&#39;Baloo 2&#39;,sans-serif; font-size:0.95em; color:var(--red); font-weight:700; margin-bottom:6px;">📍 You're at: 🎪 Piccadilly Circus</div>
      <p style="font-size:0.97em; color:#333; margin-bottom:12px;">Start with the boring phrase below — then <strong>make it amazing!</strong></p>
      <div style="background:#f0f0f0; border-radius:10px; padding:11px 15px; margin-bottom:16px; font-size:0.93em; color:#555;">
