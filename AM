const stations = [
  {
    name: "Tower Hill",
    options: ["King's Cross", "Tower Hill", "London Bridge", "Westminster"],
    clues: [
      "🐦‍⬛ Ravens live here and are protected by a very old royal law. Legend says that if the ravens ever leave, the whole kingdom will fall!",
