  {
    noun: "a clock",
    baseNoun: "clock",
    station: "🕐 Westminster",
    adjectives: ["enormous", "ancient", "golden", "famous", "grand", "gleaming", "towering", "magnificent"],
    postModifiers: [
      "whose deep, booming chimes could be heard across the whole city",
      "that had stopped working on a rainy Tuesday afternoon",
      "hidden from view behind a cluster of very tall trees"
    ]
  }
];

// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────

let a1 = { q: 0, clue: 0, score: 0, answered: false };
let a2 = { q: 0, score: 0, adjs: [], post: null, checked: false };
let completed = [];

// ─────────────────────────────────────────────
// NAV
// ─────────────────────────────────────────────

function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}
function goHome() { show('home'); }
function restartAll() {
  a1 = { q: 0, clue: 0, score: 0, answered: false };
  a2 = { q: 0, score: 0, adjs: [], post: null, checked: false };
  completed = [];
  show('home');
}

// ─────────────────────────────────────────────
// ACTIVITY 1
// ─────────────────────────────────────────────

function startActivity1() {
  a1 = { q: 0, clue: 0, score: 0, answered: false };
  renderA1();
  show('act1');
}

function renderA1() {
  const q = stations[a1.q];
  const total = stations.length;

  document.getElementById('a1-counter').textContent = `Station ${a1.q + 1} of ${total}`;
  document.getElementById('a1-score').textContent = a1.score;
  document.getElementById('a1-progress').style.width = `${(a1.q / total) * 100}%`;

  // Step dots
  document.getElementById('a1-dots').innerHTML = q.clues.map((_, i) =>
    `<div class="step-dot ${i < a1.clue ? 'done' : i === a1.clue ? 'active' : ''}"></div>`
  ).join('') + `<span style="margin-left:6px; font-size:0.82em; color:#666; font-weight:600;">Clue ${a1.clue + 1} of ${q.clues.length}</span>`;

  // Clues
  const cluesEl = document.getElementById('a1-clues');
  cluesEl.innerHTML = '';
  for (let i = 0; i <= a1.clue; i++) {
    const d = document.createElement('div');
    d.className = 'clue-box';
    d.innerHTML = `<div class="clue-label">Clue ${i + 1}</div>${q.clues[i]}`;
    cluesEl.appendChild(d);
  }

  // Reveal button
  const revWrap = document.getElementById('a1-reveal-wrap');
  revWrap.style.display = (a1.clue < q.clues.length - 1 && !a1.answered) ? 'block' : 'none';

  // Options — always show them
  const optsEl = document.getElementById('a1-options');
  if (!a1.answered) {
    optsEl.innerHTML = q.options.map(opt =>
      `<button class="option-btn" onclick="selectStation(\`${opt}\`)">${opt}</button>`
    ).join('');
  }

  document.getElementById('a1-feedback').innerHTML = '';
  document.getElementById('a1-next-wrap').innerHTML = '';
}

function revealNextClue() {
  a1.clue++;
  renderA1();
}

function selectStation(choice) {
  if (a1.answered) return;
  const q = stations[a1.q];
  a1.answered = true;
  const correct = choice === q.name;
  if (correct) a1.score++;

  document.getElementById('a1-score').textContent = a1.score;
  document.getElementById('a1-reveal-wrap').style.display = 'none';

  document.getElementById('a1-options').innerHTML = q.options.map(opt => {
    let cls = '';
    if (opt === q.name) cls = 'correct';
    else if (opt === choice && !correct) cls = 'wrong';
    return `<button class="option-btn ${cls}" disabled>${opt}</button>`;
  }).join('');

  const fb = document.getElementById('a1-feedback');
  fb.innerHTML = correct
    ? `<div class="feedback-box feedback-correct">✅ <strong>Well predicted! You've arrived at ${q.name}!</strong><br><span style="font-weight:400; font-size:0.88em; display:block; margin-top:6px;">🧠 ${q.funFact}</span></div>`
    : `<div class="feedback-box feedback-wrong">❌ <strong>Not quite — this station was ${q.name}.</strong><br><span style="font-weight:400; font-size:0.88em; display:block; margin-top:6px;">🧠 ${q.funFact}</span></div>`;

  const nw = document.getElementById('a1-next-wrap');
  if (a1.q < stations.length - 1) {
    nw.innerHTML = `<button class="btn btn-navy" onclick="nextStation()">Next station ➡️</button>`;
  } else {
    nw.innerHTML = `<button class="btn btn-green" onclick="finishA1()">Finished! 🎉</button>`;
  }
}

function nextStation() {
  a1.q++;
  a1.clue = 0;
  a1.answered = false;
  renderA1();
}

function finishA1() {
  completed.push({ name: 'Mystery Station', score: a1.score, total: stations.length });
  showEnd();
}

// ─────────────────────────────────────────────
// ACTIVITY 2
// ─────────────────────────────────────────────

function startActivity2() {
  a2 = { q: 0, score: 0, adjs: [], post: null, checked: false };
  renderA2();
  show('act2');
}

function renderA2() {
  const q = phrases[a2.q];
  a2.adjs = []; a2.post = null; a2.checked = false;

  document.getElementById('a2-counter').textContent = `Phrase ${a2.q + 1} of ${phrases.length}`;
  document.getElementById('a2-score').textContent = a2.score;
  document.getElementById('a2-progress').style.width = `${(a2.q / phrases.length) * 100}%`;
  document.getElementById('a2-station').textContent = `📍 You're at: ${q.station}`;
  document.getElementById('a2-basic').textContent = q.noun;
  document.getElementById('a2-feedback').innerHTML = '';
  document.getElementById('a2-next-wrap').innerHTML = '';

  document.getElementById('a2-adj-bank').innerHTML = q.adjectives.map(adj =>
    `<div class="adj-chip" onclick="toggleAdj('${adj}')" id="chip-${adj}">${adj}</div>`
  ).join('');

  document.getElementById('a2-post-options').innerHTML = q.postModifiers.map((pm, i) =>
    `<label class="post-option" id="postopt-${i}" onclick="selectPost(${i})">
      <input type="radio" name="postmod" value="${i}"> ${pm}
    </label>`
  ).join('');

  updatePreview();
}

function toggleAdj(adj) {
  if (a2.checked) return;
  const chip = document.getElementById(`chip-${adj}`);
  const idx = a2.adjs.indexOf(adj);
  if (idx === -1) { a2.adjs.push(adj); chip.classList.add('selected'); }
  else { a2.adjs.splice(idx, 1); chip.classList.remove('selected'); }
  updatePreview();
}

function selectPost(i) {
  if (a2.checked) return;
  document.querySelectorAll('.post-option').forEach((el, idx) => el.classList.toggle('selected', idx === i));
  document.querySelectorAll('input[name=postmod]')[i].checked = true;
  a2.post = i;
  updatePreview();
}

function updatePreview() {
  const q = phrases[a2.q];
  const p = document.getElementById('a2-preview');
  if (a2.adjs.length === 0 && a2.post === null) {
    p.innerHTML = `<span style="color:rgba(255,255,255,0.4); font-style:italic; font-size:0.95em;">Pick some adjectives above to start building...</span>`;
    return;
  }
  let html = 'I saw ';
  if (a2.adjs.length > 0) html += `<span class="phrase-adj">${a2.adjs.join(', ')}</span>&nbsp;`;
  html += `<span class="phrase-noun">${q.baseNoun}</span>`;
  if (a2.post !== null) html += `&nbsp;<span class="phrase-post">${q.postModifiers[a2.post]}</span>`;
  html += '.';
  p.innerHTML = html;
}

function checkPhrase() {
  if (a2.checked) return;
  const q = phrases[a2.q];
  const fb = document.getElementById('a2-feedback');

  if (a2.adjs.length < 2) {
    fb.innerHTML = `<div class="feedback-box feedback-wrong">⚠️ You need at least <strong>2 adjectives</strong> to make a proper expanded noun phrase — go on, add more!</div>`;
    return;
  }
  if (a2.post === null) {
    fb.innerHTML = `<div class="feedback-box feedback-wrong">⚠️ Don't forget to choose a phrase to add after the noun (Step 2)!</div>`;
    return;
  }

  a2.checked = true;
  a2.score++;
  document.getElementById('a2-score').textContent = a2.score;

  const full = `I saw ${a2.adjs.join(', ')} ${q.baseNoun} ${q.postModifiers[a2.post]}.`;

  fb.innerHTML = `<div class="feedback-box feedback-correct">
    ✅ <strong>Brilliant work!</strong><br>
    <em style="display:block; margin: 8px 0; font-size:1em; color:#155724;">"${full}"</em>
    <span style="font-size:0.87em; font-weight:400; color:#2d6a4f;">
      The adjectives before the noun are called <strong>pre-modifiers</strong>.<br>
      The phrase after the noun is a <strong>post-modifier</strong>.<br>
      Together they make a brilliant <strong>expanded noun phrase</strong>! 🌟
    </span>
  </div>`;

  document.querySelectorAll('.adj-chip').forEach(c => c.style.pointerEvents = 'none');
  document.querySelectorAll('.post-option').forEach(c => c.style.pointerEvents = 'none');

  const nw = document.getElementById('a2-next-wrap');
  if (a2.q < phrases.length - 1) {
    nw.innerHTML = `<button class="btn btn-navy" onclick="nextPhrase()">Next phrase ➡️</button>`;
  } else {
    nw.innerHTML = `<button class="btn btn-green" onclick="finishA2()">Finished! 🎉</button>`;
  }
}

function nextPhrase() { a2.q++; renderA2(); }

function finishA2() {
  completed.push({ name: 'Phrase Builder', score: a2.score, total: phrases.length });
  showEnd();
}

// ─────────────────────────────────────────────
// END
// ─────────────────────────────────────────────

function showEnd() {
  const totalC = completed.reduce((s, a) => s + a.score, 0);
  const totalQ = completed.reduce((s, a) => s + a.total, 0);
  document.getElementById('end-score').textContent = `${totalC} / ${totalQ}`;
  const pct = totalQ > 0 ? totalC / totalQ : 0;
  let star = pct === 1 ? '🌟 Perfect score! You\'re a Tube genius AND an English superstar!'
    : pct >= 0.75 ? '🎉 Fantastic work! Your inference skills and noun phrases are really impressive!'
    : pct >= 0.5 ? '👍 Good effort! Keep practising — you\'re really getting there!'
    : '🚇 Great try! Every journey starts somewhere. Have another go and you\'ll do even better!';
  const summary = completed.map(a => `<p style="margin:4px 0; font-size:0.9em; color:#444;">• ${a.name}: <strong>${a.score}/${a.total}</strong></p>`).join('');
  document.getElementById('end-msg').innerHTML = `<p style="margin-bottom:12px;">${star}</p>${summary}`;
  show('end');
}
</script>


