      <div id="a2-adj-bank" class="adj-bank"><div class="adj-chip" onclick="toggleAdj(&#39;enormous&#39;)" id="chip-enormous">enormous</div><div class="adj-chip" onclick="toggleAdj(&#39;shiny&#39;)" id="chip-shiny">shiny</div><div class="adj-chip" onclick="toggleAdj(&#39;noisy&#39;)" id="chip-noisy">noisy</div><div class="adj-chip" onclick="toggleAdj(&#39;red&#39;)" id="chip-red">red</div><div class="adj-chip" onclick="toggleAdj(&#39;double-decker&#39;)" id="chip-double-decker">double-decker</div><div class="adj-chip" onclick="toggleAdj(&#39;ancient&#39;)" id="chip-ancient">ancient</div><div class="adj-chip" onclick="toggleAdj(&#39;battered&#39;)" id="chip-battered">battered</div><div class="adj-chip" onclick="toggleAdj(&#39;speedy&#39;)" id="chip-speedy">speedy</div></div>

      <p class="section-label">Step 2 — Add a phrase after the noun</p>
      <div id="a2-post-options" class="post-options"><label class="post-option" id="postopt-0" onclick="selectPost(0)">
      <input type="radio" name="postmod" value="0"> that rumbled noisily past the dazzling circus lights
    </label><label class="post-option" id="postopt-1" onclick="selectPost(1)">
      <input type="radio" name="postmod" value="1"> which was completely empty inside
    </label><label class="post-option" id="postopt-2" onclick="selectPost(2)">
      <input type="radio" name="postmod" value="2"> parked quietly beside a sleeping pigeon
    </label></div>

      <p class="section-label">Your expanded noun phrase:</p>
      <div class="phrase-preview" id="a2-preview"><span style="color:rgba(255,255,255,0.4); font-style:italic; font-size:0.95em;">Pick some adjectives above to start building...</span></div>

      <div id="a2-feedback"></div>
      <div style="text-align:center; margin-top:14px;">
        <button class="btn btn-red" onclick="checkPhrase()">Check my phrase! ✅</button>
      </div>
    </div>
    <div style="text-align:center; margin-top:6px;" id="a2-next-wrap"></div>
  </div>
</div>

<!-- END SCREEN -->
<div id="end" class="screen">
  <div class="tube-header">
    <div class="main-title">🏆 Journey Complete!</div>
  </div>
  <div class="end-container">
    <div class="certificate">
      <div style="font-size:3.5em;">🎉</div>
      <div class="cert-title">Well done, traveller!</div>
      <div class="cert-score" id="end-score"></div>
      <div class="cert-msg" id="end-msg"></div>
