.activity-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
.activity-card {
  background: white;
  border-radius: 16px;
  padding: 24px 16px;
  box-shadow: 0 4px 16px rgba(0,54,136,0.14);
