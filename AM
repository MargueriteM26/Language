        <div class="line-badge" style="background: var(--red)">Inference &amp; Prediction</div>
      </div>
      <div class="activity-card" onclick="startActivity2()">
        <div class="card-emoji">✍️</div>
        <h3>Phrase Builder</h3>
        <p>Take a boring little phrase and build it into something brilliant using expanded noun phrases!</p>
        <div class="line-badge" style="background: var(--navy)">Expanded Noun Phrases</div>
      </div>
    </div>
    <p style="color:#777; font-size: 0.88em;">Complete both activities to see your full score! 🏆</p>
  </div>
</div>

<!-- ACTIVITY 1: MYSTERY STATION -->
<div id="act1" class="screen active">
  <div class="tube-header">
    <div class="main-title">🔍 Mystery Station</div>
  </div>
  <div class="activity-container">
    <button class="back-btn" onclick="goHome()">← Back to menu</button>
