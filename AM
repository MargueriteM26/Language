    baseNoun: "guard",
    station: "💂 St James's Park",
    adjectives: ["tall", "proud", "scarlet", "silent", "magnificent", "stern", "smart", "still"],
    postModifiers: [
      "who stood without moving for three whole hours",
      "who was secretly reading a book under his enormous hat",
      "riding very slowly past on a small bicycle"
